source "https://rubygems.org"

# Local development matches the GitHub Pages classic build closely enough.
# (GitHub Pages builds from `main` with its own pinned environment and ignores
# this Gemfile; it is only used for `bundle exec jekyll serve` locally.)
gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jekyll-sitemap", "~> 1.4"   # also whitelisted on GitHub Pages
end
